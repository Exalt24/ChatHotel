# SMTP credentials for ActionMailer (used by config/environments/*.rb and app/mailers/user_mailer.rb).
# Copy this file to .env and fill in real values. Never commit the real .env.
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password

# Optional overrides for the mailer transport (defaults: smtp.gmail.com : 587).
# SMTP_ADDRESS=smtp.gmail.com
# SMTP_PORT=587
